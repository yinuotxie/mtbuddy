{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MTBUDDY Workstation",
  "version": "0.1.0",
  "identifier": "com.mtbuddy.workstation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MTBUDDY Workstation",
        "width": 1360,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"]
  }
}
